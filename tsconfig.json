{
    "compilerOptions": {
        "module": "commonjs",
        "moduleResolution": "node",
        "target": "ES2023",
        "lib": ["ES2023"],
        "sourceMap": true,
        "declaration": false,
        "removeComments": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "dist"
    },
    "exclude": ["node_modules"]
}
